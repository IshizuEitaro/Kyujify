{
  "name": "kyujify",
  "displayName": "Kyujify: Shinjitai ↔ Kyujitai Converter",
  "description": "Convert between modern and traditional Japanese characters, Kyujitai and Shinjitai",
  "version": "2.0.0",
  "publisher": "Ishizue",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Formatters"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/IshizuEitaro/Kyujify"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kyujify.toKyujitai",
        "title": "Convert to Kyujitai",
        "category": "Kyujify"
      },
      {
        "command": "kyujify.toShinjitai",
        "title": "Convert to Shinjitai",
        "category": "Kyujify"
      },
      {
        "command": "kyujify.cycleVariants",
        "title": "Kyujify: Cycle Variants",
        "category": "Kyujify"
      },
      {
        "command": "kyujify.applyKakikae",
        "title": "Kyujify: Apply Kakikae",
        "category": "Kyujify"
      }
    ],
    "configuration": {
      "title": "Kyujify",
      "properties": {
        "kyujify.conversionPairsFile": {
          "type": "string",
          "default": "./data/default_pairs.json",
          "description": "Path to the JSON file containing conversion pairs."
        },
        "kyujify.variantsFile": {
          "type": "string",
          "default": "./data/default_variants.json",
          "description": "Path to the JSON file defining variant cycles as arrays, e.g. [[\"闘\",\"鬥\",\"鬪\",\"鬬\"]]. Used by Kyujify: Cycle Variants."
        },
        "kyujify.kakikaeFile": {
          "type": "string",
          "default": "./data/default_kakikae.json",
          "description": "Path to the JSON file defining kakikae (代用語) rules with {\"new\",\"old\",\"words\"} entries. Used by Kyujify: Apply Kakikae."
        },
        "kyujify.lineStartSymbol": {
          "type": "string",
          "default": "",
          "description": "Symbol that indicates a line should be converted. Leave blank to convert all text. Can be a string."
        },
        "kyujify.exclusions": {
          "type": "array",
          "default": [
            "欠缺"
          ],
          "description": "List of words to exclude from conversion.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "kyujify.toKyujitai",
          "group": "1_modification",
          "when": "editorHasSelection"
        },
        {
          "command": "kyujify.toShinjitai",
          "group": "1_modification",
          "when": "editorHasSelection"
        },
        {
          "command": "kyujify.toKyujitai",
          "group": "1_modification"
        },
        {
          "command": "kyujify.toShinjitai",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
